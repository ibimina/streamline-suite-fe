{
  "name": "streamline-suite-fe",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "lint:check": "eslint . --ext .ts,.tsx,.js,.jsx",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --watchAll=false --passWithNoTests",
    "test:integration": "jest --testPathPattern=integration --passWithNoTests",
    "test:e2e": "playwright test",
    "test:e2e:production": "playwright test --config=playwright.config.production.ts",
    "test:production": "npm run test:ci && npm run test:e2e",
    "test:a11y": "jest --testPathPattern=accessibility --passWithNoTests",
    "test:smoke": "jest --testPathPattern=smoke --passWithNoTests",
    "analyze": "cross-env ANALYZE=true next build",
    "lighthouse:ci": "echo 'Lighthouse CI disabled due to security vulnerabilities. Use lighthouse:manual instead'",
    "lighthouse:manual": "echo 'Run: npx lighthouse https://your-deployed-url --output=html --output-path=./lighthouse-report.html'",
    "lighthouse:production": "echo 'Lighthouse CI disabled. Use lighthouse:manual instead'",
    "postbuild": "next-sitemap",
    "clean": "rimraf .next out coverage",
    "prepare": "husky install",
    "commit": "echo 'Use: git commit -m \"type: description\" (e.g., feat: add new feature)'",
    "commitlint": "commitlint --edit",
    "pre-commit-check": "npm run format && npm run lint && npm run type-check",
    "commit-check": "echo '✅ Run npm run pre-commit-check before committing'",
    "setup-hooks": "node scripts/setup-hooks.js",
    "manual-commit": "npm run pre-commit-check && git add -A"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@reduxjs/toolkit": "^2.10.1",
    "axios": "^1.13.5",
    "class-variance-authority": "^0.7.1",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "playwright": "^1.56.1",
    "query-string": "^9.3.1",
    "react": "19.2.0",
    "react-day-picker": "^9.12.0",
    "react-dom": "19.2.0",
    "react-hook-form": "^7.67.0",
    "react-phone-number-input": "^3.4.14",
    "react-redux": "^9.2.0",
    "react-toastify": "^11.0.5",
    "recharts": "^3.3.0",
    "redux-persist": "^6.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@next/bundle-analyzer": "^16.1.6",
    "@playwright/test": "^1.56.1",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "baseline-browser-mapping": "^2.9.19",
    "cross-env": "^7.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.2.11",
    "next-sitemap": "^4.2.3",
    "prettier": "^3.4.1",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix --max-warnings=0 --cache  --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css,scss}": [
      "prettier --write"
    ],
    "*.html": [
      "prettier --write"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged",
      "commit-msg": "commitlint --edit",
      "pre-push": "npm run type-check && npm run test:ci"
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "type-enum": [
        2,
        "always",
        [
          "feat",
          "fix",
          "docs",
          "style",
          "refactor",
          "perf",
          "test",
          "build",
          "ci",
          "chore",
          "revert"
        ]
      ],
      "subject-case": [
        2,
        "never",
        [
          "sentence-case",
          "start-case",
          "pascal-case",
          "upper-case"
        ]
      ],
      "subject-empty": [
        2,
        "never"
      ],
      "subject-full-stop": [
        2,
        "never",
        "."
      ],
      "header-max-length": [
        2,
        "always",
        72
      ]
    }
  }
}
